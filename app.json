{
  "expo": {
    "name": "Mad Libs Fun",
    "slug": "madlibs-app",
    "version": "1.0.0",
    "scheme": "madlibs",
    "newArchEnabled": true,
    "orientation": "portrait",
    "platforms": ["ios", "android"],
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF8E7"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.example.madlibsapp"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFF8E7"
      },
      "package": "com.example.madlibsapp"
    },
    "plugins": ["expo-router"]
  }
}